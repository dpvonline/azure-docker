# cp terraform.tfvars.example terraform.tfvars und ausfüllen (terraform.tfvars ist gitignored)

SUBSCRIPTION_ID      = "00000000-0000-0000-0000-000000000000"
REGION               = "germanywestcentral"
# dedizierter Key für diese VM, mit ssh-keygen -t ed25519 -f ~/.ssh/dpv_core_vm_ed25519 -N "" erzeugt
ADMIN_USERNAME       = "dpvadmin"
ADMIN_SSH_PUBLIC_KEY = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDhPsdQzx+LBPyrUXAjnXYhugXmEpJNIYcWOSj3UIZoh dpvadmin@vm-dpv-core"
ADMIN_IP_CIDRS       = ["203.0.113.10/32"] # deine eigene öffentliche IP, /32

VM_SIZE                = "Standard_B2ms"
POSTGRES_DISK_SIZE_GB   = 32

KEY_VAULT_NAME              = "dpv-core-kv01"     # global eindeutig
BACKUP_STORAGE_ACCOUNT_NAME = "dpvbackups01"      # global eindeutig, nur a-z0-9

DOMAIN_AUTH       = "auth.scout-tools.de" # zum Testen; für den Live-Cutover später auf eine dpvonline.de-Subdomain umstellen
LETSENCRYPT_EMAIL = "cloudadmin@dpvonline.de"

UBUNTU_PRO_TOKEN = "C1abcDEFghiJKLmnoPQRstuVWXyz123"  # von ubuntu.com/pro, kostenloses Personal-Abo

GITHUB_REPO_SSH_URL = "git@github.com:dpvonline/azure-docker.git"

OLD_REPO_RESOURCE_GROUP = "Infra"
ACR_NAME                = "biber"

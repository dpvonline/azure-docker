# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.tfstate.lock.info
crash.log
crash.*.log

# Variable files may contain sensitive input — never commit real values
*.tfvars
*.tfvars.json
!*.tfvars.example

# Backend config contains the real storage account name/keys context
backend.hcl

# Runtime secrets rendered on the VM, never meant for git
compose/.env
compose/init-db.sql
compose/postgres/pgbackrest.conf

# Generated by cloud-init at boot (heredoc in cloud-init.yaml.tftpl); lands
# inside the repo only because /opt/dpv/scripts is a symlink into it on the VM
scripts/boot.sh

# SSH / deploy keys generated locally during setup
*.pem
id_ed25519*

# Terraform CLI config
.terraformrc
terraform.rc

# IDE / OS
.idea
.DS_Store
